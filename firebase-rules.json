{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      ".indexOn": ["role", "createdAt"],

      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.superadmin === true || auth.uid === 'tcWCQtILJNcahfAQA3qakrUP9Nv1')",

        ".write": "auth != null && (auth.uid === $uid || auth.token.superadmin === true || auth.uid === 'tcWCQtILJNcahfAQA3qakrUP9Nv1')",

        "role": {
          ".write": "auth != null && ((auth.uid === $uid && (!data.exists()) && newData.val() === 'pending') || ((auth.token.superadmin === true || auth.uid === 'tcWCQtILJNcahfAQA3qakrUP9Nv1') && (newData.val() === 'approved' || newData.val() === 'rejected' || newData.val() === 'pending')) )"
        },

        "cryptoSalt": {
          ".write": "auth != null && auth.uid === $uid && (!data.exists())"
        },

        "counters": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          ".indexOn": ["status"],
          "$counterId": {
            ".validate": "newData.hasChildren(['id','name','status'])"
          }
        },

        "services": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          ".indexOn": ["name"],
          "$serviceId": {
            ".validate": "newData.hasChildren(['id','name'])"
          }
        },

        "assignments": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          "$counterId": {
            ".validate": "newData.hasChildren(['counterId','services'])"
          }
        },

        "queue": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          "$serviceId": {
            ".indexOn": ["timestamp","status"]
          }
        },

        "tokens": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          ".indexOn": ["date","counterId"]
        },

        "kiosks": {
          ".read": "auth != null && (auth.uid === $uid || auth.token.superadmin === true || auth.uid === 'tcWCQtILJNcahfAQA3qakrUP9Nv1')",
          ".write": "auth != null && (auth.uid === $uid || auth.token.superadmin === true || auth.uid === 'tcWCQtILJNcahfAQA3qakrUP9Nv1')",
          ".indexOn": ["status"],
          "$kioskId": {
            ".validate": "newData.hasChildren(['id','name','status'])"
          }
        },

        "kioskActivity": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          ".indexOn": ["timestamp","kioskId"]
        }
      }
    },

    "kioskUsers": {
      ".read": "auth != null",
      ".indexOn": ["role", "createdAt", "organizationId"],

      "$kioskId": {
        ".read": "auth != null && (auth.uid === $kioskId || auth.token.kiosk === true)",
        ".write": "auth != null && (root.child('users').child(auth.uid).exists())",

        "role": {
          ".write": "root.child('users').child(auth.uid).exists()"
        },

        "organizationId": {
          ".write": "root.child('users').child(auth.uid).exists()"
        }
      }
    }
  }
}
